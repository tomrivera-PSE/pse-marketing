# Vercel Postgres (auto-set when you provision via Vercel dashboard → Storage)
POSTGRES_URL=

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=

# Notification recipient (defaults to info@payrollsynergyexperts.com)
# NOTIFICATION_EMAIL=info@payrollsynergyexperts.com

# Anthropic API key — required for the CHAP AI widget on /chap-ai
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
